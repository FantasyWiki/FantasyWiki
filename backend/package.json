{
  "name": "backend",
  "type": "module",
  "engines": {
    "node": "24.15.0",
    "npm": "11.14.1"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify --var WORKERS_CI_BRANCH:$WORKERS_CI_BRANCH",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest run",
    "test-coverage": "vitest run --coverage",
    "db:init:local": "wrangler d1 migrations apply db --local",
    "db:migrate:remote": "wrangler d1 migrations apply db --remote",
    "format": "prettier --check .",
    "formatfix": "prettier --write .",
    "lint": "eslint . --max-warnings 0",
    "lintfix": "eslint --fix .",
    "test:integration": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@hono/oauth-providers": "^0.8.5",
    "@js-temporal/polyfill": "^0.5.1",
    "axios": "^1.16.0",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "@cloudflare/workers-types": "^4.20260423.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.16",
    "better-sqlite3": "^12.9.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.4.0"
  }
}
