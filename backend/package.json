{
  "name": "backend",
  "type": "module",
  "engines": {
    "node": "24.15.0",
    "npm": "11.13.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify --var WORKERS_CI_BRANCH:$WORKERS_CI_BRANCH",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest run",
    "test-coverage": "vitest run --coverage",
    "format": "prettier --check .",
    "formatfix": "prettier --write .",
    "lint": "eslint .",
    "lintfix": "eslint --fix ."
  },
  "dependencies": {
    "@hono/oauth-providers": "^0.8.5",
    "@js-temporal/polyfill": "^0.5.1",
    "axios": "^1.16.0",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.16",
    "wrangler": "^4.4.0"
  }
}
